# Database
DATABASE_URL="postgresql://taxibot:taxibot_password_2026@localhost:5432/taxibot_crm"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate_random_secret_here" # openssl rand -base64 32

# Seed del admin inicial (npm run db:seed)
SEED_ADMIN_EMAIL="admin@rodolfoborja.com"
SEED_ADMIN_PASSWORD="cambia_esta_clave"
SEED_ADMIN_NOMBRE="Administrador"

# Jelou API (para webhooks y notificaciones)
JELOU_API_URL="https://api.jelou.ai"
JELOU_API_KEY="your_jelou_api_key"

# Deuna (Pagos)
DEUNA_API_KEY="your_deuna_api_key"
DEUNA_WEBHOOK_SECRET="your_deuna_webhook_secret"
DEUNA_ENV="sandbox" # sandbox | production

# WhatsApp Business API
WHATSAPP_API_URL="https://graph.facebook.com/v17.0"
WHATSAPP_ACCESS_TOKEN="your_whatsapp_access_token"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"

# Google Maps (opcional)
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# Configuración
NODE_ENV="development" # development | production
PORT=3000

# Logs
LOG_LEVEL="info" # debug | info | warn | error
